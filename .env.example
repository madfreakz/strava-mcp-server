# Strava API credentials — create at https://www.strava.com/settings/api
# (Authorization Callback Domain must be set to "localhost")
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Where rotating refresh + access tokens are persisted. Default if unset: ~/.config/strava-mcp/tokens.json
# The tokens file is written mode 0600 by the OAuth bootstrap; never commit it.
STRAVA_TOKENS_PATH=

# Root of your Obsidian vault — sync writes per-run notes under {vault}/Lifestyle/Runs/
# and a dashboard at {vault}/Lifestyle/Running-Dashboard.md.
# Leave unset to disable Obsidian sync (other tools still work).
OBSIDIAN_VAULT_PATH=

# Local port the OAuth bootstrap listens on for the redirect callback.
# Must match the Authorization Callback Domain you configured in Strava (localhost is fine).
# Default: 42424
STRAVA_OAUTH_PORT=
