{
  "name": "strava-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Strava running data (incl. Runna workout detection) + Obsidian sync",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --noCheck",
    "build:watch": "tsc --noCheck --watch",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "start": "node dist/index.js",
    "dev": "tsc --noCheck && node dist/index.js",
    "oauth": "tsc --noCheck && node dist/auth/oauth-bootstrap.js",
    "sync": "node dist/cli/sync.js",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "axios": "^1.7.0",
    "dotenv": "^16.5.0",
    "open": "^10.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.6"
  }
}
